{
  "name": "pubg-ranking-bot",
  "version": "1.0.0",
  "description": "Bot Discord para ranking interno de PUBG com cadastro admin, PUBG API, PostgreSQL e Railway.",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
